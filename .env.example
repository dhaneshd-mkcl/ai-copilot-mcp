# === AI COPILOT ENVIRONMENT TEMPLATE ===

# Server Config
HOST=0.0.0.0
PORT=8000
DEBUG=false

# LLM Config (Ollama)
LLM_BACKEND=ollama
LLM_BASE_URL=http://localhost:11434
LLM_API_KEY=
LLM_MODEL=qwen3-coder:latest
LLM_TIMEOUT=300
LLM_MAX_RETRIES=3

# Vision Model Config
VISION_MODEL=qwen3-vl:7b
VISION_BASE_URL=http://localhost:11434
VISION_API_KEY=

# Professional Search API (Tavily)
TAVILY_API_KEY=

# Embedding Config (Remote or Local Ollama)
USE_EMBEDDING=true
EMBED_BASE_URL=http://localhost:11434
EMBED_API_KEY=
EMBEDDING_MODEL=nomic-embed-text:v1.5

# Database & Cache (Docker)
USE_REDIS=true
REDIS_URL=redis://localhost:6379/0
USE_PGVECTOR=true
PG_URL=postgresql://postgres:postgres@localhost:5432/ai_copilot

# Storage & Local Workspace
MAX_FILE_SIZE_MB=10
ALLOWED_BASE_PATH=

# Logic & Persistence Limits
MAX_TURNS=50
MAX_HISTORY=100
MAX_CONTEXT_CHARS=80000
SESSION_TTL=3600

# Optional integrations
GH_TOKEN=
JIRA_URL=
JIRA_EMAIL=
JIRA_TOKEN=
